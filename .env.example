# ---- LLM ----
LLM_PROVIDER=alibaba_cloud_model_studio
LLM_API_KEY=...
LLM_BASE_URL=...
LLM_MODEL=qwen3-max
LLM_TIMEOUT=60

# ---- Voice / TTS ----
VOICE_PROVIDER=dashscope
VOICE_API_KEY=...
VOICE_MODEL=cosyvoice-v3-plus
VOICE_VOICE=...

# ---- Video Generation ----
VIDEO_PROVIDER=dashscope
VIDEO_API_KEY=...
VIDEO_MODEL=wan2.7-t2v

# ---- Storage ----
STORAGE_BACKEND=local
STORAGE_OUTPUT_DIR=./outputs

# ---- Server ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
