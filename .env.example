# ---- LLM ----
LLM_PROVIDER=alibaba_cloud_model_studio
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_TIMEOUT=60

# ---- Voice / TTS ----
VOICE_PROVIDER=elevenlabs
VOICE_API_KEY=

# ---- Video Generation ----
VIDEO_PROVIDER=runway
VIDEO_API_KEY=

# ---- Storage ----
STORAGE_BACKEND=local
STORAGE_OUTPUT_DIR=./outputs

# ---- Server ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
